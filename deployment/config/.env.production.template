# =====================================================
# Student ID Card Generator - Environment Configuration
# Phase 1 Deployment - Production Environment
# =====================================================

# Database Configuration
DB_USERNAME=${DB_USERNAME}
DB_PASSWORD=${DB_PASSWORD}
DB_NAME=${DB_NAME}
DB_HOST=${DB_HOST}
DB_DIALECT=mysql
DB_PORT=3306
DB_POOL_MAX=20
DB_POOL_MIN=2
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# Server Configuration
PORT=34567
NODE_ENV=production
TRUST_PROXY=1

# JWT Configuration
JWT_SECRET_KEY=${JWT_SECRET_KEY}
JWT_EXPIRES_IN=24h

# Cloudinary Configuration (Required for ID Card file storage)
CLOUDINARY_CLOUD_NAME=${CLOUDINARY_CLOUD_NAME}
CLOUDINARY_API_KEY=${CLOUDINARY_API_KEY}
CLOUDINARY_API_SECRET=${CLOUDINARY_API_SECRET}
CLOUDINARY_FOLDER=id-cards

# ID Card Generator Configuration
ID_CARD_STORAGE_PATH=/uploads/id-cards
ID_CARD_MAX_FILE_SIZE=10485760
ID_CARD_ALLOWED_FORMATS=jpg,jpeg,png,pdf
ID_CARD_BATCH_SIZE=100
ID_CARD_PROCESSING_TIMEOUT=600000
ID_CARD_CONCURRENT_JOBS=5

# PDF Generation Configuration
PDF_GENERATION_ENGINE=react-pdf
PDF_QUALITY=high
PDF_DPI=300
PDF_COMPRESSION=true

# QR Code Configuration
QR_CODE_SIZE=100
QR_CODE_ERROR_CORRECTION=M
QR_CODE_MARGIN=4
QR_CODE_COLOR_DARK=#000000
QR_CODE_COLOR_LIGHT=#FFFFFF

# Barcode Configuration
BARCODE_FORMAT=CODE128
BARCODE_WIDTH=2
BARCODE_HEIGHT=50
BARCODE_DISPLAY_VALUE=true

# File Upload Configuration
MULTER_TEMP_DIR=/tmp/id-card-uploads
MULTER_MAX_FILES=100
MULTER_MAX_FILE_SIZE=5242880

# Logging Configuration
LOG_LEVEL=warn
LOG_FILE_PATH=./logs/id-card-generator.log
LOG_MAX_SIZE=50m
LOG_MAX_FILES=10
LOG_COMPRESS=true

# Health Check Configuration
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30000
HEALTH_CHECK_TIMEOUT=5000

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=200
RATE_LIMIT_SKIP_SUCCESSFUL=true

# CORS Configuration
CORS_ORIGIN=${FRONTEND_URL}
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-School-ID,X-Branch-ID

# Redis Configuration (Recommended for production)
REDIS_HOST=${REDIS_HOST}
REDIS_PORT=${REDIS_PORT}
REDIS_PASSWORD=${REDIS_PASSWORD}
REDIS_DB=1
REDIS_RETRY_DELAY=100
REDIS_MAX_RETRIES=3

# Monitoring Configuration
MONITORING_ENABLED=true
METRICS_PORT=9090
PROMETHEUS_ENABLED=true

# Security Configuration
HELMET_ENABLED=true
COMPRESSION_ENABLED=true
SECURITY_HEADERS=true

# Performance Configuration
CLUSTER_MODE=false
WORKER_PROCESSES=1
MEMORY_LIMIT=1024
CPU_LIMIT=1

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_INTERVAL=86400000
BACKUP_RETENTION_DAYS=30