# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=skcooly_db
DB_USERNAME=root
DB_PASSWORD=
DB_ROOT_PASSWORD=rootpassword

# Server Configuration
NODE_ENV=development
PORT=34567

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
PASSPORT_SECRET=your-passport-secret-change-in-production

# Cloudinary Configuration (Required for Remote Recitation Feature)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Audio Upload Configuration
MAX_AUDIO_SIZE=6291456  # 6MB in bytes

# Redis Configuration (Optional)
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# Logging Configuration
ENABLE_LOGGING=true
LOG_LEVEL=debug
ENABLE_DB_LOGGING=true

# Frontend Configuration
REACT_APP_API_URL=http://localhost:34567

# Email Configuration (if needed)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# File Upload Limits
MAX_FILE_SIZE=10485760  # 10MB
MAX_FILES=5

# Session Configuration
SESSION_SECRET=your-session-secret-change-in-production
SESSION_TIMEOUT=3600000  # 1 hour in milliseconds

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW=900000  # 15 minutes
RATE_LIMIT_MAX=100  # requests per window

# Security
BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=8

# Feature Flags
ENABLE_RECITATIONS=true
ENABLE_SOCKET_IO=true
ENABLE_AUDIO_TRANSCRIPTION=false  # Future feature

# Development Only
DEBUG=elite:*
