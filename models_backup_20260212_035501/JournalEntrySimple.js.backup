/**
 * Simplified Journal Entry Model
 * 
 * This is a simplified version of the JournalEntry model without foreign key constraints
 * to avoid table creation issues. The associations can be added later if needed.
 */

const { DataTypes } = require('sequelize');

module.exports = (sequelize) => {
  const JournalEntry = sequelize.define('JournalEntry', {
    id: {
      type: DataTypes.INTEGER,
      primaryKey: true,
      autoIncrement: true
    },
    entry_number: {
      type: DataTypes.STRING(50),
      allowNull: true,
      unique: true
    },
    account: {
      type: DataTypes.STRING(255),
      allowNull: false
    },
    account_code: {
      type: DataTypes.STRING(10),
      allowNull: false
    },
    account_type: {
      type: DataTypes.ENUM('Asset', 'Liability', 'Equity', 'Revenue', 'Expense', 'Contra-Revenue', 'Contra-Asset'),
      allowNull: false
    },
    debit: {
      type: DataTypes.DECIMAL(15, 2),
      allowNull: false,
      defaultValue: 0.00
    },
    credit: {
      type: DataTypes.DECIMAL(15, 2),
      allowNull: false,
      defaultValue: 0.00
    },
    description: {
      type: DataTypes.TEXT,
      allowNull: false
    },
    reference: {
      type: DataTypes.STRING(100),
      allowNull: true
    },
    transaction_date: {
      type: DataTypes.DATEONLY,
      allowNull: false,
      defaultValue: DataTypes.NOW
    },
    posting_date: {
      type: DataTypes.DATEONLY,
      allowNull: true
    },
    school_id: {
      type: DataTypes.STRING(20),
      allowNull: false
    },
    branch_id: {
      type: DataTypes.STRING(20),
      allowNull: true
    },
    student_id: {
      type: DataTypes.STRING(50),
      allowNull: true
    },
    custom_item_ref: {
      type: DataTypes.INTEGER,
      allowNull: true
    },
    status: {
      type: DataTypes.ENUM('DRAFT', 'POSTED', 'REVERSED', 'CANCELLED'),
      allowNull: false,
      defaultValue: 'POSTED'
    },
    reversal_entry_ref: {
      type: DataTypes.INTEGER,
      allowNull: true
    },
    created_by_user: {
      type: DataTypes.INTEGER,
      allowNull: false
    },
    updated_by_user: {
      type: DataTypes.INTEGER,
      allowNull: true
    },
    created_at: {
      type: DataTypes.DATE,
      defaultValue: DataTypes.NOW
    },
    updated_at: {
      type: DataTypes.DATE,
      defaultValue: DataTypes.NOW
    }
  }, {
    tableName: 'journal_entries',
    timestamps: true,
    createdAt: 'created_at',
    updatedAt: 'updated_at',
    
    // Basic indexes without foreign key constraints
    indexes: [
      {
        fields: ['school_id', 'branch_id']
      },
      {
        fields: ['account_code']
      },
      {
        fields: ['transaction_date']
      },
      {
        fields: ['status']
      },
      {
        fields: ['reference']
      },
      {
        fields: ['student_id']
      },
      {
        fields: ['custom_item_ref']
      },
      {
        unique: true,
        fields: ['entry_number']
      }
    ],
    
    // Model-level hooks for basic validation
    hooks: {
      beforeCreate: (entry, options) => {
        // Generate entry number if not provided
        if (!entry.entry_number) {
          const timestamp = Date.now();
          entry.entry_number = `JE-${entry.school_id}-${timestamp}`;
        }
        
        // Set posting date if not provided
        if (!entry.posting_date) {
          entry.posting_date = entry.transaction_date;
        }
      }
    }
  });

  // No associations to avoid foreign key constraint issues
  JournalEntry.associate = (models) => {
    // Associations disabled to avoid table creation issues
    // Can be re-enabled later if needed
  };

  return JournalEntry;
};