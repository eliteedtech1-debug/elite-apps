DELIMITER //
DROP PROCEDURE IF EXISTS CreateUpdateCASetup //
CREATE PROCEDURE CreateUpdateCASetup(
    IN p_ca_type ENUM('CA1', 'CA2', 'CA3', 'EXAM'),
    IN p_academic_year VARCHAR(20),
    IN p_term VARCHAR(50),
    IN p_overall_contribution DECIMAL(5,2),
    IN p_weeks JSON
)
BEGIN
    DECLARE v_week_number INT;
    DECLARE v_max_score DECIMAL(5,2);
    DECLARE i INT DEFAULT 0;
    DECLARE week_count INT;
    
    DECLARE EXIT HANDLER FOR SQLEXCEPTION
    BEGIN
        ROLLBACK;
        RESIGNAL;
    END;
    
    START TRANSACTION;
    
    -- Deactivate existing setup
    UPDATE ca_setup 
    SET is_active = FALSE 
    WHERE ca_type = p_ca_type 
      AND academic_year = p_academic_year 
      AND term = p_term;
    
    -- Get week count from JSON
    SET week_count = JSON_LENGTH(p_weeks);
    
    -- Insert new weeks
    WHILE i < week_count DO
        SET v_week_number = JSON_UNQUOTE(JSON_EXTRACT(p_weeks, CONCAT('$[', i, '].week_number')));
        SET v_max_score = JSON_UNQUOTE(JSON_EXTRACT(p_weeks, CONCAT('$[', i, '].max_score')));
        
        INSERT INTO ca_setup (
            ca_type, 
            week_number, 
            max_score, 
            overall_contribution_percent, 
            academic_year, 
            term,
            is_active
        ) VALUES (
            p_ca_type,
            v_week_number,
            v_max_score,
            p_overall_contribution,
            p_academic_year,
            p_term,
            TRUE
        );
        
        SET i = i + 1;
    END WHILE;
    
    COMMIT;
END //
DELIMITER ;
