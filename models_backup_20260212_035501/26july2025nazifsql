-- 17. Create/Update Grade Boundaries
DELIMITER //
DROP PROCEDURE IF EXISTS CreateUpdateGradeBoundaries //
CREATE PROCEDURE CreateUpdateGradeBoundaries(
    IN p_ca_type ENUM('CA1', 'CA2', 'CA3', 'EXAM', 'OVERALL'),
    IN p_academic_year VARCHAR(20),
    IN p_term VARCHAR(50),
    IN p_grades JSON
)
BEGIN
    DECLARE v_grade VARCHAR(5);
    DECLARE v_min_percentage DECIMAL(5,2);
    DECLARE v_max_percentage DECIMAL(5,2);
    DECLARE i INT DEFAULT 0;
    DECLARE grade_count INT;
    
    DECLARE EXIT HANDLER FOR SQLEXCEPTION
    BEGIN
        ROLLBACK;
        RESIGNAL;
    END;
    
    START TRANSACTION;
    
    -- Deactivate existing boundaries
    UPDATE grade_boundaries 
    SET is_active = FALSE 
    WHERE ca_type = p_ca_type 
      AND academic_year = p_academic_year 
      AND term = p_term;
    
    -- Get grade count from JSON
    SET grade_count = JSON_LENGTH(p_grades);
    
    -- Insert new grades
    WHILE i < grade_count DO
        SET v_grade = JSON_UNQUOTE(JSON_EXTRACT(p_grades, CONCAT('$[', i, '].grade')));
        SET v_min_percentage = JSON_UNQUOTE(JSON_EXTRACT(p_grades, CONCAT('$[', i, '].min_percentage')));
        SET v_max_percentage = JSON_UNQUOTE(JSON_EXTRACT(p_grades, CONCAT('$[', i, '].max_percentage')));
        
        INSERT INTO grade_boundaries (
            ca_type,
            grade,
            min_percentage,
            max_percentage,
            academic_year,
            term,
            is_active
        ) VALUES (
            p_ca_type,
            v_grade,
            v_min_percentage,
            v_max_percentage,
            p_academic_year,
            p_term,
            TRUE
        );
        
        SET i = i + 1;
    END WHILE;
    
    COMMIT;
END //
DELIMITER ;

-- 18. Insert/Update Weekly Score
DELIMITER //
DROP PROCEDURE IF EXISTS InsertUpdateScore //
CREATE PROCEDURE InsertUpdateScore(
    IN p_admission_no VARCHAR(50),
    IN p_subject_code VARCHAR(20),
    IN p_class_code VARCHAR(20),
    IN p_academic_week_id INT,
    IN p_score DECIMAL(5,2),
    IN p_ca_type ENUM('CA1', 'CA2', 'CA3', 'EXAM'),
    IN p_week_number INT,
    IN p_academic_year VARCHAR(20),
    IN p_term VARCHAR(50)
)
BEGIN
    DECLARE v_ca_setup_id INT;
    DECLARE v_max_score DECIMAL(5,2);
    DECLARE v_is_locked BOOLEAN DEFAULT FALSE;
    
    -- Get CA setup info
    SELECT id, max_score INTO v_ca_setup_id, v_max_score
    FROM ca_setup 
    WHERE ca_type = p_ca_type 
      AND week_number = p_week_number
      AND academic_year = p_academic_year
      AND term = p_term
      AND is_active = TRUE;
    
    -- Check if existing score is locked
    SELECT is_locked INTO v_is_locked
    FROM weekly_scores
    WHERE student_admission_no = p_admission_no
      AND subject_code = p_subject_code
      AND academic_week_id = p_academic_week_id
      AND assessment_type = p_ca_type;
    
    -- Validate score and lock status
    IF v_is_locked THEN
        SIGNAL SQLSTATE '45000' 
        SET MESSAGE_TEXT = 'Score is locked and cannot be modified';
    END IF;
    
    IF p_score > v_max_score THEN
        SIGNAL SQLSTATE '45000' 
        SET MESSAGE_TEXT = 'Score exceeds maximum allowed score of max_score';
    END IF;
    
    -- Insert or update score
    INSERT INTO weekly_scores (
        student_admission_no, 
        subject_code, 
        class_code, 
        academic_week_id, 
        ca_setup_id,
        score, 
        max_score, 
        week_number,
        assessment_type
    ) VALUES (
        p_admission_no,
        p_subject_code,
        p_class_code,
        p_academic_week_id,
        v_ca_setup_id,
        p_score,
        v_max_score,
        p_week_number,
        p_ca_type
    )
    ON DUPLICATE KEY UPDATE 
        score = VALUES(score),
        updated_at = CURRENT_TIMESTAMP;
END //
DELIMITER ;

