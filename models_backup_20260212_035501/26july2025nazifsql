-- =====================================================
-- TABLE CREATION SECTION
-- =====================================================

-- 1. CA Setup Configuration Table
CREATE TABLE IF NOT EXISTS ca_setup (
    id INT PRIMARY KEY AUTO_INCREMENT,
    ca_type ENUM('CA1', 'CA2', 'CA3', 'EXAM') NOT NULL,
    week_number INT NOT NULL,
    max_score DECIMAL(5,2) NOT NULL,
    overall_contribution_percent DECIMAL(5,2) NOT NULL,
    academic_year VARCHAR(20) NOT NULL,
    term VARCHAR(50) NOT NULL,
    is_active BOOLEAN DEFAULT TRUE,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    
    UNIQUE KEY unique_ca_week (ca_type, week_number, academic_year, term),
    INDEX idx_ca_type_year_term (ca_type, academic_year, term),
    INDEX idx_active (is_active)
);

-- 2. Grade Boundaries Table
CREATE TABLE IF NOT EXISTS grade_boundaries (
    id INT PRIMARY KEY AUTO_INCREMENT,
    ca_type ENUM('CA1', 'CA2', 'CA3', 'EXAM', 'OVERALL') NOT NULL,
    grade VARCHAR(5) NOT NULL,
    min_percentage DECIMAL(5,2) NOT NULL,
    max_percentage DECIMAL(5,2) NOT NULL,
    academic_year VARCHAR(20) NOT NULL,
    term VARCHAR(50) NOT NULL,
    is_active BOOLEAN DEFAULT TRUE,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    
    INDEX idx_ca_type_boundaries (ca_type, academic_year, term, is_active)
);

-- 3. Weekly Scores Table (Enhanced)
CREATE TABLE IF NOT EXISTS weekly_scores (
    id INT PRIMARY KEY AUTO_INCREMENT,
    student_admission_no VARCHAR(50) NOT NULL,
    subject_code VARCHAR(20) NOT NULL,
    class_code VARCHAR(20) NOT NULL,
    academic_week_id INT NOT NULL,
    ca_setup_id INT NOT NULL,
    score DECIMAL(5,2) DEFAULT 0,
    max_score DECIMAL(5,2) NOT NULL,
    week_number INT NOT NULL,
    assessment_type ENUM('CA1', 'CA2', 'CA3', 'EXAM') DEFAULT 'CA1',
    is_locked BOOLEAN DEFAULT FALSE,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    
    FOREIGN KEY (academic_week_id) REFERENCES Academic_weeks(id),
    FOREIGN KEY (ca_setup_id) REFERENCES ca_setup(id),
    UNIQUE KEY unique_score (student_admission_no, subject_code, academic_week_id, assessment_type),
    INDEX idx_student_subject (student_admission_no, subject_code),
    INDEX idx_class_week (class_code, academic_week_id),
    INDEX idx_assessment_type (assessment_type)
);

-- 4. Week Access Control Table
CREATE TABLE IF NOT EXISTS week_access_control (
    id INT PRIMARY KEY AUTO_INCREMENT,
    class_code VARCHAR(20) NOT NULL,
    subject_code VARCHAR(20) NOT NULL,
    ca_type ENUM('CA1', 'CA2', 'CA3', 'EXAM') NOT NULL,
    current_week_number INT NOT NULL DEFAULT 1,
    unlocked_previous_weeks JSON,
    final_results_generated BOOLEAN DEFAULT FALSE,
    academic_year VARCHAR(20) NOT NULL,
    term VARCHAR(50) NOT NULL,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    
    UNIQUE KEY unique_access_control (class_code, subject_code, ca_type, academic_year, term)
);

