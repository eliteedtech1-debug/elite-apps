{
  "name": "database_administrator_agent",
  "description": "Specialized agent for handling large database imports and MySQL optimization",
  "capabilities": [
    "mysql_optimization",
    "large_file_import",
    "timeout_handling",
    "chunk_processing",
    "foreign_key_management"
  ],
  "tools": {
    "mysql_config_optimizer": {
      "max_allowed_packet": "1073741824",
      "innodb_buffer_pool_size": "512M",
      "wait_timeout": "28800",
      "interactive_timeout": "28800",
      "net_read_timeout": "600",
      "net_write_timeout": "600",
      "bulk_insert_buffer_size": "256M"
    },
    "import_strategies": [
      "chunk_based_import",
      "parallel_processing",
      "memory_optimization",
      "connection_pooling"
    ]
  },
  "config": {
    "chunk_size": 1000,
    "retry_attempts": 3,
    "timeout_handling": true,
    "foreign_key_checks": false,
    "autocommit": false
  },
  "collaboration_protocol": {
    "protocol_reference": "../collaboration_protocol.yaml",
    "role": "database_agent",
    "communication_schedule": {
      "daily_standup": "9:00 AM UTC - 15 minutes (Participant)",
      "technical_design_review": "Weekly, Wednesday 2:00 PM UTC (Presenter)",
      "stakeholder_demo": "Bi-weekly, Friday 10:00 AM UTC (Technical Demo)",
      "risk_review": "Weekly, Monday 4:00 PM UTC (Participant)"
    },
    "decision_authority": {
      "architectural_decisions": "Primary approver (with backend_agent and financial_domain_agent)",
      "database_schema": "Primary decision authority",
      "query_optimization": "Primary decision authority",
      "migration_strategy": "Primary decision authority"
    },
    "integration_checkpoints": {
      "phase1_completion": "Primary validator for database schema & API endpoints",
      "phase2_completion": "Validator for data integration",
      "phase3_completion": "Participant in performance validation"
    },
    "escalation_path": "Technical blockers → Project coordinator → Relevant technical leads"
  }
}
