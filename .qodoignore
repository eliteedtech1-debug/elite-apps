# Qodo Ignore File
# This file specifies which files and directories Qodo should ignore during analysis

# Dependencies
node_modules/
*/node_modules/
elscholar-api/node_modules/
elscholar-ui/node_modules/

# Build outputs
build/
dist/
*/build/
*/dist/
elscholar-api/build/
elscholar-ui/build/
elscholar-ui/dist/

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# nyc test coverage
.nyc_output/

# Dependency directories
jspm_packages/

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# parcel-bundler cache (https://parceljs.org/)
.cache
.parcel-cache

# next.js build output
.next

# nuxt.js build output
.nuxt

# vuepress build output
.vuepress/dist

# Serverless directories
.serverless

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/

# TernJS port file
.tern-port

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Git
.git/
.gitignore

# Package lock files (too large and not useful for analysis)
package-lock.json
yarn.lock

# Minified files
*.min.js
*.min.css

# Source maps
*.map

# Temporary files
*.tmp
*.temp
temp/
tmp/

# Database files
*.db
*.sqlite
*.sqlite3

# Compiled binary addons
build/Release

# Documentation build outputs
docs/_build/
docs/build/

# Test artifacts
test-results/
screenshots/
videos/

# Babel cache
.babel-cache/

# ESLint cache
.eslintcache

# Prettier cache
.prettiercache

# Stylelint cache
.stylelintcache

# Jest cache
.jest/

# Webpack cache
.webpack/

# Rollup cache
.rollup.cache/

# Storybook build outputs
storybook-static/

# Temporary folders
.tmp/
.temp/

# Editor backup files
*~
*.bak
*.backup

# Lock files
*.lock

# Cache directories
.cache/
cache/

# Public build assets (usually generated)
public/build/
public/dist/

# Specific to this project - test files and documentation that are not code
*.md
!README.md
!CONTRIBUTING.md
!CHANGELOG.md

# Large data files
*.csv
*.xlsx
*.xls
*.pdf

# Image and media files (not relevant for code analysis)
*.jpg
*.jpeg
*.png
*.gif
*.svg
*.ico
*.webp
*.mp4
*.mp3
*.wav

# Configuration files that contain sensitive information
config/production.js
config/staging.js
.env.*

# Backup files
*.backup
*.bak

# Archive files
*.zip
*.tar
*.tar.gz
*.rar
*.7z