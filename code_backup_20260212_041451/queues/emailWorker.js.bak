const { Worker } = require('bullmq');
const nodemailer = require('nodemailer');
const { connection, EMAIL_JOB_TYPES } = require('./emailQueue');
const { getEmailTemplate, validateTemplateData } = require('./emailTemplates');
const db = require('../models');

// Enhanced email transporter with better error handling
const createEmailTransporter = () => {
  const config = {
    host: process.env.SMTP_HOST || 'smtp.gmail.com',
    port: parseInt(process.env.SMTP_PORT) || 587,
    secure: false,
    auth: {
      user: process.env.SMTP_USERNAME,
      pass: process.env.SMTP_PASSWORD
    },
    tls: {
      rejectUnauthorized: false
    },
    connectionTimeout: 15000,
    greetingTimeout: 10000,
    socketTimeout: 15000,
    pool: true,           // Use connection pooling
    maxConnections: 5,    // Max concurrent connections
    maxMessages: 100,     // Max messages per connection
    rateLimit: 10         // Max 10 emails per second
  };
  
  console.log('📧 Email worker transporter config:', {
    host: config.host,
    port: config.port,
    user: config.auth.user,
    hasPassword: !!config.auth.pass,
    pool: config.pool,
    rateLimit: config.rateLimit
  });
  
  return nodemailer.createTransport(config);
};

// Fallback email transporter configuration
const createFallbackTransporter = () => {
  const fallbackConfig = {
    host: 'smtp.gmail.com',
    port: 587,
    secure: false,
    auth: {
      user: 'eliteedtech1@gmail.com',
      pass: 'ELITE-2006'
    },
    tls: {
      rejectUnauthorized: false
    },
    connectionTimeout: 15000,
    greetingTimeout: 10000,
    socketTimeout: 15000,
    pool: true,
    maxConnections: 3,
    maxMessages: 50,
    rateLimit: 5
  };
  
  console.log('📧 Fallback email transporter config:', {
    host: fallbackConfig.host,
    port: fallbackConfig.port,
    user: fallbackConfig.auth.user,
    hasPassword: !!fallbackConfig.auth.pass
  });
  
  return nodemailer.createTransport(fallbackConfig);
};

const transporter = createEmailTransporter();
const fallbackTransporter = createFallbackTransporter();

// Test transporter connection on startup
const testConnection = async () => {
  try {
    console.log('🔍 Testing primary email transporter connection...');
    await transporter.verify();
    console.log('✅ Primary email transporter connection verified');
    
    console.log('🔍 Testing fallback email transporter connection...');
    await fallbackTransporter.verify();
    console.log('✅ Fallback email transporter connection verified');
    
    return true;
  } catch (error) {
    console.log('❌ Email transporter connection failed:', error.message);
    return false;
  }
};

// Email sending function with enhanced error handling and fallback
const sendEmail = async (mailOptions, jobId) => {
  try {
    console.log(`📤 Sending email for job ${jobId}:`, {
      to: mailOptions.to,
      subject: mailOptions.subject,
      from: mailOptions.from
    });
    
    const result = await transporter.sendMail(mailOptions);
    
    console.log(`✅ Email sent successfully for job ${jobId}:`, {
      messageId: result.messageId,
      response: result.response
    });
    
    return {
      success: true,
      messageId: result.messageId,
      response: result.response,
      usedFallback: false
    };
  } catch (error) {
    console.log(`❌ Primary email sending failed for job ${jobId}:`, error.message);
    console.log(`🔄 Attempting fallback SMTP for job ${jobId}...`);
    
    try {
      // Update mail options to use fallback sender
      const fallbackMailOptions = {
        ...mailOptions,
        from: {
          name: 'Elite Scholar System',
          address: 'eliteedtech1@gmail.com'
        }
      };
      
      const fallbackResult = await fallbackTransporter.sendMail(fallbackMailOptions);
      
      console.log(`✅ Email sent via fallback SMTP for job ${jobId}:`, {
        messageId: fallbackResult.messageId,
        response: fallbackResult.response
      });
      
      return {
        success: true,
        messageId: fallbackResult.messageId,
        response: fallbackResult.response,
        usedFallback: true
      };
    } catch (fallbackError) {
      console.log(`❌ Fallback email sending also failed for job ${jobId}:`, fallbackError.message);
      
      // Categorize errors for better retry logic
      const errorType = categorizeEmailError(error);
      
      throw {
        ...error,
        errorType,
        retryable: isRetryableError(errorType),
        fallbackAttempted: true,
        fallbackError: fallbackError.message
      };
    }
  }
};

// Categorize email errors
const categorizeEmailError = (error) => {
  if (error.code === 'ETIMEDOUT' || error.code === 'ECONNECTION') {
    return 'CONNECTION_ERROR';
  } else if (error.code === 'EAUTH') {
    return 'AUTHENTICATION_ERROR';
  } else if (error.responseCode >= 500 && error.responseCode < 600) {
    return 'SERVER_ERROR';
  } else if (error.responseCode >= 400 && error.responseCode < 500) {
    return 'CLIENT_ERROR';
  } else if (error.code === 'EENVELOPE') {
    return 'INVALID_RECIPIENT';
  } else {
    return 'UNKNOWN_ERROR';
  }
};

// Determine if error is retryable
const isRetryableError = (errorType) => {
  const retryableErrors = [
    'CONNECTION_ERROR',
    'SERVER_ERROR',
    'UNKNOWN_ERROR'
  ];
  return retryableErrors.includes(errorType);
};

// Process email jobs
const processEmailJob = async (job) => {
  const { type, ...data } = job.data;
  
  // Fetch school details if school_id is provided\n  let schoolDetails = null;\n  if (data.school_id) {\n    try {\n      const schoolResult = await db.sequelize.query(\n        `SELECT school_name, short_name, badge_url FROM school_setup WHERE school_id = ?`,\n        {\n          replacements: [data.school_id],\n          type: db.sequelize.QueryTypes.SELECT\n        }\n      );\n      \n      if (schoolResult.length > 0) {\n        schoolDetails = schoolResult[0];\n      }\n    } catch (schoolError) {\n      console.error(`⚠️ Error fetching school details for school_id ${data.school_id}:`, schoolError.message);\n      // Continue without school details if there's an error\n    }\n  }\n\n  console.log(`🔄 Processing email job ${job.id} of type: ${type}`);
  
  try {
    // Validate template data
    validateTemplateData(type, data);
    
    // Get email template
    let { subject, html } = getEmailTemplate(type, data);

    // Enhance email with school branding if school details are available
    if (schoolDetails) {
      // Enhance subject with school name
      subject = `[${schoolDetails.short_name || schoolDetails.school_name}] ${subject}`;
      
      // Add school signature or branding to the email HTML if it doesn't already have one
      if (!html.includes('<!-- SCHOOL_BRANDING -->')) {
        const schoolSignature = `
          <div style="margin-top: 30px; padding-top: 20px; border-top: 1px solid #e0e0e0; font-size: 12px; color: #666;">
            <p>Sent from:<br>
            <strong>${schoolDetails.school_name}</strong><br>
            ${schoolDetails.badge_url ? `<img src="${schoolDetails.badge_url}" alt="${schoolDetails.school_name} Logo" style="max-width: 80px; margin-top: 5px; display: block;">` : ''}
            </p>
          </div>
        `;
        html += schoolSignature;
      }
    }
    
    // Prepare mail options
    const mailOptions = {
      from: {
        name: schoolDetails \n          ? `${schoolDetails.school_name} - School Management System` \n          : process.env.SMTP_FROM_NAME || 'School Management System',
        address: process.env.SMTP_FROM_ADDRESS || process.env.SMTP_USERNAME
      },
      to: data.to,
      subject: subject,
      html: html
    };
    
    // Handle special cases for different job types
    switch (type) {
      case EMAIL_JOB_TYPES.BULK_EMAIL:
        return await processBulkEmail(job, data);
      
      case EMAIL_JOB_TYPES.EMAIL_CHANGE_VERIFICATION:
      case EMAIL_JOB_TYPES.EMAIL_VERIFICATION:
      case EMAIL_JOB_TYPES.PASSWORD_RESET:
        // High priority emails - add extra logging
        console.log(`🔐 Processing high-priority email: ${type} for user ${data.user_id}`);
        break;
    }
    
    // Send email
    const result = await sendEmail(mailOptions, job.id);
    
    // Update job progress
    await job.updateProgress(100);

    // Save to messaging_history table for single emails
    try {
      const school_id = data.school_id || 'system';
      const branch_id = data.branch_id || 'unknown';
      const sender_id = data.sender_id || 'system';
      const costPerMessage = data.cost_per_message || 0;

      await db.sequelize.query(
        `INSERT INTO messaging_history
         (school_id, branch_id, sender_id, sender_type, recipient_type, recipient_id, recipient_name,
          recipient_identifier, channel, message_type, recipients_count, message_text, message_subject, cost, status, created_at)
         VALUES (?, ?, ?, 'admin', 'mixed', ?, ?, ?, 'email', 'single', 1, ?, ?, ?, 'sent', NOW())`,
        {
          replacements: [
            school_id,
            branch_id,
            sender_id,
            data.user_id || 'unknown',
            data.user_name || data.to?.split('@')[0] || 'Unknown',
            data.to,
            data.message || '',
            mailOptions.subject,
            costPerMessage
          ],
          type: db.sequelize.QueryTypes.INSERT
        }
      );

      console.log(`✅ Saved single email history for ${data.to}`);
    } catch (historyError) {
      console.error('⚠️ Error saving email message history:', historyError);
      // Continue even if history saving fails
    }

    // Log success
    console.log(`✅ Email job ${job.id} completed successfully:`, {
      type,
      to: data.to,
      messageId: result.messageId,
      usedFallback: result.usedFallback
    });

    return {
      success: true,
      type,
      recipient: data.to,
      messageId: result.messageId,
      usedFallback: result.usedFallback,
      timestamp: new Date().toISOString()
    };
    
  } catch (error) {
    console.log(`❌ Email job ${job.id} failed:`, {
      type,
      error: error.message,
      errorType: error.errorType,
      retryable: error.retryable,
      fallbackAttempted: error.fallbackAttempted
    });
    
    // Add error context to job
    await job.log(`Error: ${error.message} (Type: ${error.errorType || 'UNKNOWN'}) - Fallback: ${error.fallbackAttempted ? 'Yes' : 'No'}`);
    
    // Throw error to trigger retry logic
    throw error;
  }
};

// Process bulk email jobs with fallback support
const processBulkEmail = async (job, data) => {
  const { recipients, subject, message, sender_name, campaign_id } = data;
  
  console.log(`📬 Processing bulk email job ${job.id}:`, {
    recipients_count: recipients.length,
    subject,
    campaign_id
  });
  
  const results = {
    total: recipients.length,
    sent: 0,
    failed: 0,
    fallbackUsed: 0,
    errors: []
  };
  
  // Process recipients in batches to avoid overwhelming SMTP server
  const batchSize = 10;
  const batches = [];
  
  for (let i = 0; i < recipients.length; i += batchSize) {
    batches.push(recipients.slice(i, i + batchSize));
  }
  
  for (let batchIndex = 0; batchIndex < batches.length; batchIndex++) {
    const batch = batches[batchIndex];
    
    console.log(`📦 Processing batch ${batchIndex + 1}/${batches.length} (${batch.length} recipients)`);
    
    // Process batch concurrently
    const batchPromises = batch.map(async (recipient) => {
      try {
        let { subject: emailSubject, html } = getEmailTemplate('BULK_EMAIL', {
          subject,
          message,
          sender_name,
          campaign_id
        });

        // Enhance email with school branding if school details are available
        if (schoolDetails) {
          // Enhance subject with school name
          emailSubject = `[${schoolDetails.short_name || schoolDetails.school_name}] ${emailSubject}`;
          
          // Add school signature or branding to the email HTML if it doesn't already have one
          if (!html.includes('<!-- SCHOOL_BRANDING -->')) {
            const schoolSignature = `
              <div style="margin-top: 30px; padding-top: 20px; border-top: 1px solid #e0e0e0; font-size: 12px; color: #666;">
                <p>Sent from:<br>
                <strong>${schoolDetails.school_name}</strong><br>
                ${schoolDetails.badge_url ? `<img src="${schoolDetails.badge_url}" alt="${schoolDetails.school_name} Logo" style="max-width: 80px; margin-top: 5px; display: block;">` : ''}
                </p>
              </div>
            `;
            html += schoolSignature;
          }
        }

        const mailOptions = {
          from: {
            name: schoolDetails
              ? `${schoolDetails.school_name} - School Management System`
              : sender_name || process.env.SMTP_FROM_NAME || 'School Management System',
            address: process.env.SMTP_FROM_ADDRESS || process.env.SMTP_USERNAME
          },
          to: recipient,
          subject: emailSubject,
          html: html
        };
        
        const result = await sendEmail(mailOptions, `${job.id}-${recipient}`);
        results.sent++;
        
        if (result.usedFallback) {
          results.fallbackUsed++;
        }
        
      } catch (error) {
        results.failed++;
        results.errors.push({
          recipient,
          error: error.message,
          fallbackAttempted: error.fallbackAttempted
        });
        console.log(`❌ Failed to send bulk email to ${recipient}:`, error.message);
      }
    });
    
    await Promise.all(batchPromises);
    
    // Update job progress
    const progress = Math.round(((batchIndex + 1) / batches.length) * 100);
    await job.updateProgress(progress);
    
    // Add delay between batches to respect rate limits
    if (batchIndex < batches.length - 1) {
      await new Promise(resolve => setTimeout(resolve, 1000));
    }
  }
  
  console.log(`📊 Bulk email job ${job.id} completed:`, results);

  // Save to messaging_history table for unified tracking
  try {
    const school_id = data.school_id || 'system';
    const branch_id = data.branch_id || 'unknown';
    const sender_id = data.sender_id || 'system';

    const recipientsList = recipients.map(email => ({
      email: email,
      name: email.split('@')[0], // Use email prefix as name if not provided
      id: null
    }));

    const messageType = recipientsList.length > 1 ? 'bulk' : 'single';
    const costPerMessage = data.cost_per_message || 0;
    const totalCostForMessage = costPerMessage * results.sent;

    if (messageType === 'single') {
      // Single email - use individual fields
      await db.sequelize.query(
        `INSERT INTO messaging_history
         (school_id, branch_id, sender_id, sender_type, recipient_type, recipient_id, recipient_name,
          recipient_identifier, channel, message_type, recipients_count, message_text, message_subject, cost, status, created_at)
         VALUES (?, ?, ?, 'admin', 'mixed', ?, ?, ?, 'email', 'single', 1, ?, ?, ?, 'sent', NOW())`,
        {
          replacements: [
            school_id,
            branch_id,
            sender_id,
            recipientsList[0].id || 'unknown',
            recipientsList[0].name,
            recipientsList[0].email,
            message,
            subject,
            costPerMessage
          ],
          type: db.sequelize.QueryTypes.INSERT
        }
      );
    } else {
      // Bulk email - save 1 record with recipients list
      await db.sequelize.query(
        `INSERT INTO messaging_history
         (school_id, branch_id, sender_id, sender_type, recipient_type, channel, message_type,
          recipients_count, recipients_list, message_text, message_subject, cost, status, created_at)
         VALUES (?, ?, ?, 'admin', 'mixed', 'email', 'bulk', ?, ?, ?, ?, ?, 'sent', NOW())`,
        {
          replacements: [
            school_id,
            branch_id,
            sender_id,
            results.sent, // Use actual sent count
            JSON.stringify(recipientsList),
            message,
            subject,
            totalCostForMessage
          ],
          type: db.sequelize.QueryTypes.INSERT
        }
      );
    }

    console.log(`✅ Saved bulk email history: ${messageType} message with ${results.sent} recipient(s)`);
  } catch (historyError) {
    console.error('⚠️ Error saving email message history:', historyError);
    // Continue even if history saving fails
  }

  return {
    success: true,
    type: 'BULK_EMAIL',
    campaign_id,
    results,
    timestamp: new Date().toISOString()
  };
};

// Create email worker
const emailWorker = new Worker('email-queue', processEmailJob, {
  connection,
  concurrency: 5, // Process up to 5 jobs concurrently
  removeOnComplete: 100,
  removeOnFail: 50,
  settings: {
    stalledInterval: 30000,    // Check for stalled jobs every 30 seconds
    maxStalledCount: 1         // Max number of times a job can be stalled
  }
});

// Worker event listeners
emailWorker.on('ready', () => {
  console.log('🚀 Email worker is ready and waiting for jobs');
  testConnection();
});

emailWorker.on('active', (job) => {
  console.log(`⚡ Email worker started processing job ${job.id}`);
});

emailWorker.on('completed', (job, result) => {
  console.log(`✅ Email worker completed job ${job.id}:`, {
    type: result.type,
    recipient: result.recipient || 'bulk',
    messageId: result.messageId,
    usedFallback: result.usedFallback
  });
});

emailWorker.on('failed', (job, err) => {
  console.log(`❌ Email worker failed job ${job.id}:`, {
    error: err.message,
    errorType: err.errorType,
    retryable: err.retryable,
    fallbackAttempted: err.fallbackAttempted,
    attemptsMade: job.attemptsMade,
    attemptsTotal: job.opts.attempts
  });
});

emailWorker.on('stalled', (job) => {
  console.log(`⚠️ Email worker job ${job.id} stalled`);
});

emailWorker.on('error', (err) => {
  console.log('❌ Email worker error:', err.message);
});

// Graceful shutdown
process.on('SIGTERM', async () => {
  console.log('📧 Shutting down email worker...');
  await emailWorker.close();
  await transporter.close();
  await fallbackTransporter.close();
  console.log('📧 Email worker shut down complete');
});

process.on('SIGINT', async () => {
  console.log('📧 Shutting down email worker...');
  await emailWorker.close();
  await transporter.close();
  await fallbackTransporter.close();
  console.log('📧 Email worker shut down complete');
  process.exit(0);
});

module.exports = {
  emailWorker,
  transporter,
  fallbackTransporter,
  processEmailJob,
  testConnection
};