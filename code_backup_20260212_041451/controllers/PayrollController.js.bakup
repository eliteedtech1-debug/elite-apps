- 2794     :   /**
- 2795     :    * Helper function to create journal entries and payment entries for payroll disbursement
- 2796     :    * Implements proper double-entry accounting for salary payments
- 2797     :    * Also creates payment_entries records for financial reporting
- 2798     :    */
- 2799     :   static async createPayrollJournalEntries(payrollLine, period_month, school_id, branch_id, created_by, transaction) {
- 2800     :     try {
- 2801     :       const reference = `PAYROLL-${period_month}-STAFF-${payrollLine.staff_id}`;
- 2802     :       const transaction_date = new Date().toISOString().split('T')[0];
- 2803     : 
- 2804     :       // Fetch detailed breakdown from payroll_items
- 2805     :       const payrollItems = await sequelize.query(`
- 2806     :         SELECT item_type, item_name, amount
- 2807     :         FROM payroll_items
- 2808     :         WHERE payroll_line_id = ?
- 2809     :       `, {
- 2810     :         replacements: [payrollLine.payroll_line_id],
- 2811     :         type: sequelize.QueryTypes.SELECT,
- 2812     :         transaction
- 2813     :       });
- 2814     : 
- 2815     :       // Calculate amounts
- 2816     :       const basic_salary = parseFloat(payrollLine.basic_salary) || 0;
- 2817     :       const total_allowances = parseFloat(payrollLine.total_allowances) || 0;
- 2818     :       const total_deductions = parseFloat(payrollLine.total_deductions) || 0;
- 2819     :       const total_loans = parseFloat(payrollLine.total_loans) || 0;
- 2820     :       const net_pay = parseFloat(payrollLine.net_pay) || 0;
- 2821     :       const gross_salary = basic_salary + total_allowances;
- 2822     : 
- 2823     :       // Accounting Rules:
- 2824     :       // 1. Basic Salary + Allowances REDUCE school revenue (expense to school)
- 2825     :       // 2. Deductions (tax, union, etc.) INCREASE school revenue (school collects on behalf of govt/unions)
- 2826     :       // 3. Loan repayment INCREASES school revenue (recovers money school lent to staff)
- 2827     : 
- 2828     :       const journal_entries = [];
- 2829     :       const payment_entries = [];
- 2830     : 
- 2831     :       // Entry 1: DEBIT Salary Expense (Total compensation = Basic + Allowances)
- 2832     :       // This reduces school profit as it's an expense
- 2833     :       journal_entries.push({
- 2834     :         account: 'Salary Expense',
- 2835     :         account_code: '5010',
- 2836     :         account_type: 'Expense',
- 2837     :         debit: gross_salary,
- 2838     :         credit: 0,
- 2839     :         description: `Salary expense for staff ${payrollLine.staff_id} - ${period_month} (Basic: ${basic_salary.toFixed(2)}, Allowances: ${total_allowances.toFixed(2)})`,
- 2840     :         reference,
- 2841     :         transaction_date,
- 2842     :         school_id,
- 2843     :         branch_id,
- 2844     :         status: 'POSTED',
- 2845     :         created_by
- 2846     :       });
- 2847     : 
- 2848     :       // Entry 2: CREDIT Cash/Bank (Net pay disbursed to staff)
- 2849     :       // This is the actual cash outflow from school
- 2850     :       journal_entries.push({
- 2851     :         account: 'Cash - Bank Account',
- 2852     :         account_code: '1010',
- 2853     :         account_type: 'Asset',
- 2854     :         debit: 0,
- 2855     :         credit: net_pay,
- 2856     :         description: `Salary disbursement for staff ${payrollLine.staff_id} - ${period_month}`,
- 2857     :         reference,
- 2858     :         transaction_date,
- 2859     :         school_id,
- 2860     :         branch_id,
- 2861     :         status: 'POSTED',
- 2862     :         created_by
- 2863     :       });
- 2864     : 
- 2865     :       // Entry 3: CREDIT Taxes and Statutory Deductions Payable
- 2866     :       // School withholds these amounts and must remit to government/unions
- 2867     :       // This INCREASES school's liability (money collected but owed to govt)
- 2868     :       if (total_deductions > 0) {
- 2869     :         journal_entries.push({
- 2870     :           account: 'Taxes and Statutory Deductions Payable',
- 2871     :           account_code: '2030',
- 2872     :           account_type: 'Liability',
- 2873     :           debit: 0,
- 2874     :           credit: total_deductions,
- 2875     :           description: `Tax/statutory deductions withheld for staff ${payrollLine.staff_id} - ${period_month}`,
- 2876     :           reference,
- 2877     :           transaction_date,
- 2878     :           school_id,
- 2879     :           branch_id,
- 2880     :           status: 'POSTED',
- 2881     :           created_by
- 2882     :         });
- 2883     :       }
- 2884     : 
- 2885     :       // Entry 4: CREDIT Staff Loans Receivable (Loan recovery)
- 2886     :       // This REDUCES the asset (loans receivable) as staff repays the loan
- 2887     :       // The school recovers money it previously lent
- 2888     :       if (total_loans > 0) {
- 2889     :         journal_entries.push({
- 2890     :           account: 'Staff Loans Receivable',
- 2891     :           account_code: '1220',
- 2892     :           account_type: 'Asset',
- 2893     :           debit: 0,
- 2894     :           credit: total_loans,
- 2895     :           description: `Loan recovery for staff ${payrollLine.staff_id} - ${period_month}`,
- 2896     :           reference,
- 2897     :           transaction_date,
- 2898     :           school_id,
- 2899     :           branch_id,
- 2900     :           status: 'POSTED',
- 2901     :           created_by
- 2902     :         });
- 2903     :       }
- 2904     : 
- 2905     :       // Verify accounting equation: Debits = Credits
- 2906     :       const total_debits = journal_entries.reduce((sum, entry) => sum + parseFloat(entry.debit), 0);
- 2907     :       const total_credits = journal_entries.reduce((sum, entry) => sum + parseFloat(entry.credit), 0);
- 2908     : 
- 2909     :       if (Math.abs(total_debits - total_credits) > 0.01) {
- 2910     :         throw new Error(`Accounting entries not balanced! Debits: ${total_debits}, Credits: ${total_credits}`);
- 2911     :       }
- 2912     : 
- 2913     :       // =====================================================================
- 2914     :       // CREATE PAYMENT_ENTRIES FOR FINANCIAL REPORTING
- 2915     :       // =====================================================================
- 2916     :       // payment_entries are used by FinancialAnalyticsDashboard and other reports
- 2917     :       // We create separate entries for each component of the salary disbursement
- 2918     : 
- 2919     :       // 1. Basic Salary - Debit (Expense - reduces school revenue)
- 2920     :       payment_entries.push({
- 2921     :         item_category: 'Payroll - Basic Salary',
- 2922     :         ref_no: reference,
- 2923     :         admission_no: null,
- 2924     :         class_code: null,
- 2925     :         academic_year: null,
- 2926     :         term: null,
- 2927     :         dr: basic_salary,  // Debit = Expense (reduces revenue)
- 2928     :         cr: 0,
- 2929     :         description: `Basic Salary - Staff ${payrollLine.staff_id} - ${period_month}`,
- 2930     :         school_id: school_id,
- 2931     :         branch_id: branch_id || null,
- 2932     :         payment_mode: 'Bank Transfer',
- 2933     :         payment_status: 'Paid',
- 2934     :         payment_date: transaction_date
- 2935     :       });
- 2936     : 
- 2937     :       // 2. Allowances - Debit (Expense - reduces school revenue)
- 2938     :       if (total_allowances > 0) {
- 2939     :         payment_entries.push({
- 2940     :           item_category: 'Payroll - Allowances',
- 2941     :           ref_no: reference,
- 2942     :           admission_no: null,
- 2943     :           class_code: null,
- 2944     :           academic_year: null,
- 2945     :           term: null,
- 2946     :           dr: total_allowances,  // Debit = Expense (reduces revenue)
- 2947     :           cr: 0,
- 2948     :           description: `Staff Allowances - Staff ${payrollLine.staff_id} - ${period_month}`,
- 2949     :           school_id: school_id,
- 2950     :           branch_id: branch_id || null,
- 2951     :           payment_mode: 'Bank Transfer',
- 2952     :           payment_status: 'Paid',
- 2953     :           payment_date: transaction_date
- 2954     :         });
- 2955     :       }
- 2956     : 
- 2957     :       // 3. Deductions - Credit (Revenue - increases school revenue)
- 2958     :       // School collects deductions on behalf of government/unions
- 2959     :       if (total_deductions > 0) {
- 2960     :         payment_entries.push({
- 2961     :           item_category: 'Payroll - Deductions',
- 2962     :           ref_no: reference,
- 2963     :           admission_no: null,
- 2964     :           class_code: null,
- 2965     :           academic_year: null,
- 2966     :           term: null,
- 2967     :           dr: 0,
- 2968     :           cr: total_deductions,  // Credit = Revenue (increases revenue)
- 2969     :           description: `Tax & Statutory Deductions - Staff ${payrollLine.staff_id} - ${period_month}`,
- 2970     :           school_id: school_id,
- 2971     :           branch_id: branch_id || null,
- 2972     :           payment_mode: 'Withheld',
