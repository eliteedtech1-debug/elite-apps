- 1459     :   // Staff Payroll History
- 1460     :   static async getStaffPayrollHistory(req, res) {
- 1461     :     try {
- 1462     :       const { staffId } = req.params;
- 1463     :       const school_id = req.user.school_id;
- 1464     :       
- 1465     :       const history = await sequelize.query(`
- 1466     :         SELECT 
- 1467     :           pl.*,
- 1468     :           pp.period_month,
- 1469     :           pp.period_year,
- 1470     :           pp.status as period_status,
- 1471     :           pp.approved_at,
- 1472     :           s.name as staff_name,
- 1473     :           s.employee_id
- 1474     :         FROM payroll_lines pl
- 1475     :         JOIN payroll_periods pp ON pl.period_id = pp.period_id
- 1476     :         LEFT JOIN staff s ON pl.staff_id = s.staff_id
- 1477     :         WHERE pl.staff_id = :staffId
- 1478     :         AND pp.school_id = :school_id
- 1479     :         ORDER BY pp.period_month DESC, pp.created_at DESC
- 1480     :       `, {
- 1481     :         replacements: { staffId, school_id },
- 1482     :         type: sequelize.QueryTypes.SELECT
- 1483     :       });
- 1484     : 
- 1485     :       // Calculate YTD totals
- 1486     :       const currentYear = new Date().getFullYear();
- 1487     :       const ytdData = history.filter(h => {
- 1488     :         const periodYear = parseInt(h.period_month?.split('-')[0] || h.period_year);
- 1489     :         return periodYear === currentYear;
- 1490     :       });
- 1491     : 
- 1492     :       const ytdTotals = {
- 1493     :         total_basic_salary: ytdData.reduce((sum, h) => sum + parseFloat(h.basic_salary || 0), 0),
- 1494     :         total_allowances: ytdData.reduce((sum, h) => sum + parseFloat(h.total_allowances || 0), 0),
- 1495     :         total_deductions: ytdData.reduce((sum, h) => sum + parseFloat(h.total_deductions || 0), 0),
- 1496     :         total_net_pay: ytdData.reduce((sum, h) => sum + parseFloat(h.net_pay || 0), 0),
- 1497     :         periods_count: ytdData.length
- 1498     :       };
- 1499     : 
- 1500     :       res.json({ 
- 1501     :         success: true, 
- 1502     :         data: history,
- 1503     :         ytd_totals: ytdTotals,
- 1504     :         summary: {
- 1505     :           total_periods: history.length,
- 1506     :           earliest_period: history.length > 0 ? history[history.length - 1].period_month : null,
- 1507     :           latest_period: history.length > 0 ? history[0].period_month : null
- 1508     :         }
- 1509     :       });
- 1510     :     } catch (error) {
- 1511     :       console.error('Error fetching staff history:', error);
- 1512     :       res.status(500).json({ success: false, message: 'Failed to fetch staff payroll history', error: error.message });
