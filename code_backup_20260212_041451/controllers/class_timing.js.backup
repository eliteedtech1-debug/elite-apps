const db = require("../models");
const moment = require("moment");
const EnhancedTimeSlotService = require("../services/EnhancedTimeSlotService");
const CulturalScheduleService = require("../services/CulturalScheduleService");
const NigerianEducationOptimizer = require("../services/NigerianEducationOptimizer");

const enhanced_time_slots = (req, res) => {
  const {
    query_type = "create",
    slot_id = null,
    school_id = null,
    section = null,
    slot_name = null,
    start_time = null,
    end_time = null,
    slot_type = "Academic",
    template_id = null,
    day_of_week = null
  } = req.body;

  db.sequelize
    .query(
      `CALL EnhancedTimeSlots(:query_type, :slot_id, :school_id, :section, :slot_name, :start_time, :end_time, :slot_type, :template_id, :day_of_week)`,
      {
        replacements: {
          query_type,
          slot_id,
          school_id: req.user.school_id ?? school_id,
          section,
          slot_name,
          start_time,
          end_time,
          slot_type,
          template_id,
          day_of_week,
        },
      }
    )
    .then((results) => res.json({ success: true, data: results }))
    .catch((err) => {
      console.error("Database Error in enhanced_time_slots:", err);
      res.status(500).json({ success: false, error: err.message });
    });
};

// Get Nigerian school templates
const get_nigerian_templates = async (req, res) => {
  try {
    const { school_level, region = 'all' } = req.query;
    
    const result = await EnhancedTimeSlotService.getNigerianTemplates(school_level, region);
    
    if (result.success) {
      res.json(result);
    } else {
      res.status(500).json(result);
    }
  } catch (error) {
    console.error('Error in get_nigerian_templates:', error);
    res.status(500).json({ success: false, error: error.message });
  }
};

// Generate time slots from Nigerian template
const generate_from_template = async (req, res) => {
  try {
    const { template_id, section } = req.body;
    const school_id = req.user.school_id;
    
    if (!template_id || !section) {
      return res.status(400).json({ 
        success: false, 
        error: 'template_id and section are required' 
      });
    }
    
    const result = await EnhancedTimeSlotService.generateFromTemplate(template_id, school_id, section);
    
    if (result.success) {
      // Save generated slots to database
      const promises = result.data.map(slot => {
        return db.sequelize.query(
          `INSERT INTO enhanced_time_slots 
           (slot_id, school_id, section, slot_name, start_time, end_time, duration_minutes, slot_type, template_id, day_of_week, is_active, activities)
           VALUES (:slot_id, :school_id, :section, :slot_name, :start_time, :end_time, :duration_minutes, :slot_type, :template_id, :day_of_week, :is_active, :activities)
           ON DUPLICATE KEY UPDATE updated_at = NOW()`,
          {
            replacements: slot,
            type: db.sequelize.QueryTypes.INSERT
          }
        );
      });
      
      await Promise.all(promises);
      
      res.json({ 
        success: true, 
        message: `Generated ${result.data.length} time slots from Nigerian template`,
        data: result.data 
      });
    } else {
      res.status(500).json(result);
    }
  } catch (error) {
    console.error('Error in generate_from_template:', error);
    res.status(500).json({ success: false, error: error.message });
  }
};

