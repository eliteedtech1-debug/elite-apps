// Bulk operations for time slots
async function bulk_enhanced_time_slots(req, res) {
  const timeSlots = Array.isArray(req.body) ? req.body : [req.body];

  const promises = timeSlots.map((slot) => {
    const {
      query_type = "create",
      slot_id = null,
      school_id = null,
      section = null,
      slot_name = null,
      start_time = null,
      end_time = null,
      slot_type = "Academic",
      template_id = null,
      day_of_week = null
    } = slot;

    return db.sequelize.query(
      `CALL EnhancedTimeSlots(:query_type, :slot_id, :school_id, :section, :slot_name, :start_time, :end_time, :slot_type, :template_id, :day_of_week)`,
      {
        replacements: {
          query_type,
          slot_id,
          school_id: req.user.school_id ?? school_id,
          section,
          slot_name,
          start_time,
          end_time,
          slot_type,
          template_id,
          day_of_week,
        },
      }
    );
  });

  try {
    const results = await Promise.all(promises);
    res.status(200).json({ 
      success: true, 
      message: `Processed ${timeSlots.length} time slots`,
      data: results.flat() 
    });
  } catch (error) {
    console.error("Error during bulk enhanced time slots operation:", error);
    res.status(500).json({ 
      success: false, 
      error: "An error occurred while processing the request" 
    });
  }
}

// Keep existing functions for backward compatibility
const class_timing = enhanced_time_slots;
