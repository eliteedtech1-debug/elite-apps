    query_type = "select",
    section = null,
    school_id = null,
  } = req.query;

  db.sequelize
    .query(
      `SELECT * FROM enhanced_time_slots 
       WHERE school_id = :school_id 
       AND (:section IS NULL OR section = :section)
       AND is_active = TRUE
       ORDER BY day_of_week, start_time`,
      {
        replacements: {
          school_id: school_id ?? req.user.school_id,
          section,
        },
        type: db.sequelize.QueryTypes.SELECT
      }
    )
    .then((results) => {
      res.json({ success: true, data: results });
    })
    .catch((err) => {
      console.error("Database Error in get_class_timing:", err);
      res.status(500).json({ success: false, error: err.message });
    });
};

const delete_class_timing = (req, res) => {
  const { id } = req.query;

  db.sequelize
    .query(
      `UPDATE enhanced_time_slots SET is_active = FALSE WHERE id = :id`,
      {
        replacements: { id },
        type: db.sequelize.QueryTypes.UPDATE
      }
    )
    .then(() => res.json({ success: true, message: "Time slot deactivated successfully" }))
    .catch((err) => {
      console.error("Database Error in delete_class_timing:", err);
      res.status(500).json({ success: false, error: err.message });
    });
};

const bulk_class_timing = bulk_enhanced_time_slots;

const get_time_slots = (req, res) => {
  const { section = null, school_id = null } = req.query;

  const finalSchoolId = school_id ?? req.user?.school_id;
  
  if (!finalSchoolId) {
    return res.status(400).json({ 
      success: false, 
      error: "School ID is required" 
    });
  }

  let query = `SELECT DISTINCT 
    CONCAT(start_time, ' - ', end_time) as label,
    CONCAT(start_time, ' - ', end_time) as value,
    start_time,
    end_time,
    slot_type as activities,
    section
  FROM enhanced_time_slots 
  WHERE school_id = :school_id AND is_active = TRUE`;
  
  const replacements = { school_id: finalSchoolId };
  
  if (section) {
    query += ` AND section = :section`;
    replacements.section = section;
  }
  
  query += ` ORDER BY start_time ASC`;

  db.sequelize
    .query(query, {
      replacements,
      type: db.sequelize.QueryTypes.SELECT
    })
    .then((results) => {
      res.json({ success: true, data: results });
    })
    .catch((err) => {
      console.error("Database Error in get_time_slots:", err);
      res.status(500).json({ 
        success: false, 
        error: err.message
      });
    });
};

