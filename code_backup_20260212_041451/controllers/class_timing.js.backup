};

// AI-powered timetable generation
const generate_ai_timetable = async (req, res) => {
  try {
    const { section, apply_cultural_rules = true } = req.body;
    const school_id = req.user.school_id;
    
    if (!section) {
      return res.status(400).json({ 
        success: false, 
        error: 'section is required' 
      });
    }
    
    // Get existing time slots for this section
    const timeSlots = await db.sequelize.query(
      `SELECT * FROM enhanced_time_slots 
       WHERE school_id = :school_id AND section = :section AND is_active = TRUE
       ORDER BY day_of_week, start_time`,
      {
        replacements: { school_id, section },
        type: db.sequelize.QueryTypes.SELECT
      }
    );
    
    if (timeSlots.length === 0) {
      return res.status(400).json({
        success: false,
        error: 'No time slots configured for this section. Please create time slots first.'
      });
    }
    
    // Get teacher assignments
    const assignmentsResult = await EnhancedTimeSlotService.getTeacherAssignments(school_id, section);
    if (!assignmentsResult.success) {
      return res.status(500).json(assignmentsResult);
    }
    
    // Apply Nigerian education optimization
    let optimizedSlots = EnhancedTimeSlotService.applyNigerianOptimization(
      timeSlots, 
      assignmentsResult.data
    );
    
    // Apply cultural rules if requested
    if (apply_cultural_rules) {
      const culturalResult = await CulturalScheduleService.integratePrayerTimes(optimizedSlots, school_id);
      if (culturalResult.success) {
        optimizedSlots = culturalResult.data;
      }
    }
    
    // Generate lesson_time_table entries from optimized slots
    const timetableEntries = [];
    const classes = await db.sequelize.query(
      `SELECT DISTINCT class_code, class_name FROM teacher_classes WHERE school_id = :school_id AND section = :section`,
      {
        replacements: { school_id, section },
        type: db.sequelize.QueryTypes.SELECT
      }
    );
    
    for (const classInfo of classes) {
      for (const slot of optimizedSlots) {
        if (slot.slot_type === 'Academic') {
          // Find a teacher assignment for this slot
          const assignment = assignmentsResult.data.find(a => 
            a.class_code === classInfo.class_code && 
            a.subject_priority === 'high' // Prioritize high priority subjects
          ) || assignmentsResult.data.find(a => a.class_code === classInfo.class_code);
          
          if (assignment) {
            const entry = {
              day: slot.day_of_week || 'Monday',
              class_code: classInfo.class_code,
              class_name: classInfo.class_name,
              subject: assignment.subject_name,
              subject_code: assignment.subject_code,
              teacher_id: assignment.teacher_id,
              section: section,
              start_time: slot.start_time,
              end_time: slot.end_time,
              school_id: school_id,
              status: 'Active'
            };
            
            // Insert into lesson_time_table
            await db.sequelize.query(
              `INSERT INTO lesson_time_table 
               (day, class_code, class_name, subject, subject_code, teacher_id, section, 
                start_time, end_time, school_id, status, created_at, updated_at)
               VALUES (:day, :class_code, :class_name, :subject, :subject_code, :teacher_id, 
                       :section, :start_time, :end_time, :school_id, :status, NOW(), NOW())
               ON DUPLICATE KEY UPDATE
               subject = VALUES(subject), teacher_id = VALUES(teacher_id), updated_at = NOW()`,
              {
                replacements: entry,
                type: db.sequelize.QueryTypes.INSERT
              }
            );
            
            timetableEntries.push(entry);
          }
        }
      }
    }
        // Get class information
        const [classInfo] = await db.sequelize.query(
          'SELECT class_name, class_code FROM classes WHERE section = :section AND school_id = :school_id LIMIT 1',
          {
            replacements: { section, school_id },
            type: db.sequelize.QueryTypes.SELECT
          }
        );
        
        if (classInfo) {
          timetableEntries.push({
            day: slot.day_of_week,
            class_name: classInfo.class_name,
            class_code: classInfo.class_code,
            subject: slot.subject,
            teacher_id: slot.teacher_id,
            section: section,
            start_time: slot.start_time,
            end_time: slot.end_time,
            school_id: school_id,
            branch_id: req.user.branch_id,
            status: 'Active'
          });
        }
      }
    }
    
    res.json({
      success: true,
      message: `Generated AI-optimized timetable with ${timetableEntries.length} academic periods`,
      data: {
        optimized_slots: optimizedSlots,
        timetable_entries: timetableEntries,
        optimization_summary: {
          total_slots: optimizedSlots.length,
          academic_slots: optimizedSlots.filter(s => s.slot_type === 'Academic').length,
          assigned_slots: optimizedSlots.filter(s => s.teacher_id).length,
          morning_stem_slots: optimizedSlots.filter(s => 
            s.slot_type === 'Academic' && 
            s.subject_category === 'STEM' && 
            EnhancedTimeSlotService.timeToMinutes(s.start_time) < 720
          ).length
        }
      }
    });
    
  } catch (error) {
    console.error('Error in generate_ai_timetable:', error);
    res.status(500).json({ success: false, error: error.message });
  }
};

