  generate_ai_timetable,
  get_prayer_times,
  get_ramadan_adjustments,
};

// Get AI optimization analysis
const get_optimization_analysis = async (req, res) => {
  try {
    const { school_id, section } = req.query;
    
    if (!school_id || !section) {
      return res.status(400).json({
        success: false,
        message: "School ID and section are required"
      });
    }
    
    // Get current timetable
    const currentTimetable = await db.sequelize.query(
      `SELECT * FROM lesson_time_table 
       WHERE school_id = :school_id AND section = :section AND status = 'Active'`,
      {
        replacements: { school_id, section },
        type: db.sequelize.QueryTypes.SELECT
      }
    );
    
    if (currentTimetable.length === 0) {
      return res.json({
        success: true,
        message: "No timetable found for analysis",
        data: {
          has_timetable: false,
          recommendations: [
            "Generate an AI-optimized timetable using Nigerian education templates",
            "Ensure teacher assignments are properly configured",
            "Consider cultural and religious requirements"
          ]
        }
      });
    }
    
    // Analyze current timetable using optimizer
    const stemSubjects = ['Mathematics', 'Physics', 'Chemistry', 'Biology', 'Further Mathematics'];
    
    const analysis = {
      total_periods: currentTimetable.length,
      morning_stem_count: currentTimetable.filter(entry => {
        const startHour = parseInt(entry.start_time.split(':')[0]);
        const isMorning = startHour >= 8 && startHour < 12;
        const isStem = stemSubjects.some(stem => entry.subject.includes(stem));
        return isMorning && isStem;
      }).length,
      total_stem_count: currentTimetable.filter(entry => 
        stemSubjects.some(stem => entry.subject.includes(stem))
      ).length,
      teacher_distribution: {},
      daily_distribution: {},
      conflicts: []
    };
    
    // Calculate teacher distribution
    for (const entry of currentTimetable) {
      analysis.teacher_distribution[entry.teacher_id] = 
        (analysis.teacher_distribution[entry.teacher_id] || 0) + 1;
    }
    
    // Calculate daily distribution
    for (const entry of currentTimetable) {
      analysis.daily_distribution[entry.day] = 
        (analysis.daily_distribution[entry.day] || 0) + 1;
    }
    
    // Calculate optimization score
    const stemOptimization = analysis.total_stem_count > 0 ? 
      (analysis.morning_stem_count / analysis.total_stem_count) * 100 : 0;
    
    const recommendations = [];
    
    if (stemOptimization < 70) {
      recommendations.push(`Improve STEM morning placement: Currently ${stemOptimization.toFixed(1)}%, target 70%+`);
    }
    
    if (Object.keys(analysis.teacher_distribution).length < 3) {
      recommendations.push("Consider adding more teachers to balance workload");
    }
    
    recommendations.push("Use AI optimization to automatically resolve conflicts and improve efficiency");
    
    res.json({
      success: true,
      data: {
        has_timetable: true,
        analysis,
        optimization_score: Math.round(stemOptimization),
        recommendations,
        next_steps: [
          "Click 'Generate AI Timetable' to optimize current schedule",
          "Review teacher assignments for better distribution",
          "Consider cultural adjustments for prayer times"
        ]
      }
    });
    
  } catch (error) {
    console.error('Error in get_optimization_analysis:', error);
    res.status(500).json({
      success: false,
      message: "Failed to analyze timetable",
      error: error.message
    });
  }
};
// Get enhanced time slots
const get_enhanced_time_slots = async (req, res) => {
  try {
    const { school_id, section } = req.query;
    const result = await db.sequelize.query(
      `SELECT * FROM enhanced_time_slots WHERE school_id = :school_id AND section = :section ORDER BY day, start_time`,
      { replacements: { school_id, section }, type: db.sequelize.QueryTypes.SELECT }
    );
    res.json({ success: true, data: result });
  } catch (error) {
    res.status(500).json({ success: false, error: error.message });
  }
};

// Delete enhanced time slots
const delete_enhanced_time_slots = async (req, res) => {
  try {
    const { school_id, section, ids } = req.body;
    await db.sequelize.query(
      `DELETE FROM enhanced_time_slots WHERE school_id = :school_id AND section = :section AND id IN (:ids)`,
      { replacements: { school_id, section, ids }, type: db.sequelize.QueryTypes.DELETE }
    );
    res.json({ success: true, message: "Time slots deleted successfully" });
  } catch (error) {
    res.status(500).json({ success: false, error: error.message });
  }
};

module.exports = {
