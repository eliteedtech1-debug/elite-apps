// ═══════════════════════════════════════════════════════════════
// 404 HANDLER - MUST BE LAST MIDDLEWARE
// This catches any routes that don't match the defined routes above
// ═══════════════════════════════════════════════════════════════

app.use('*', (req, res) => {
  console.log(`❌ 404 - Route not found: ${req.method} ${req.originalUrl}`);
  console.log(`📋 Available test routes: GET /banks-test, GET /test-auth, GET /api/test`);
  console.log(`🔴 THIS IS OUR NEW 404 HANDLER - If you see this, our middleware is working`);
  
  res.status(404).json({
    success: false,
    message: 'Route not found - NEW 404 HANDLER',
    path: req.originalUrl,
    method: req.method,
    timestamp: new Date().toISOString(),
    note: 'This is the NEW 404 handler from index.js - if you see this, our changes are active',
    availableTestRoutes: [
      'GET /banks - DIRECT banks route (should work)',
      'GET /banks-direct-test - Direct test route',
      'GET /banks-test - Original test route',
      'GET /test-auth - Test authentication', 
      'GET /api/test - Test API',
      'GET / - Root endpoint'
    ],
    debugInfo: {
      middlewareActive: true,
      directRoutesAdded: true,
      oldMiddlewareRemoved: true
    }
  });
});

