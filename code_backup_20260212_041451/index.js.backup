const isProduction = process.env.NODE_ENV === "production";

models.sequelize.sync({ force: false, alter: false }) 
  .then(async () => {
    console.log(`✅ Database synced safely`);
    
    // Initialize comprehensive logging system
    try {
      console.log('🚀 Initializing comprehensive logging system...');
      const { initializeLogging } = require('./logging/initializeLogging');
      await initializeLogging(app, models);
      console.log('✅ Logging system initialized successfully');
    } catch (loggingError) {
      console.error('❌ Failed to initialize logging system:', loggingError.message);
      // Continue without logging system if it fails
    }
    
    // Create verification tables if they don't exist
    try {
      await models.sequelize.query(`
        CREATE TABLE IF NOT EXISTS verification_codes (
          id INT AUTO_INCREMENT PRIMARY KEY,
          user_id VARCHAR(255) NOT NULL,
          code VARCHAR(10) NOT NULL,
          method ENUM('email', 'whatsapp', 'sms') NOT NULL DEFAULT 'email',
          purpose ENUM('password_change', 'email_verification', 'account_recovery') NOT NULL DEFAULT 'password_change',
          expires_at DATETIME NOT NULL,
          used_at DATETIME NULL,
          created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
          INDEX idx_user_id (user_id),
          INDEX idx_code (code),
          INDEX idx_expires_at (expires_at)
        )
      `);
      
      await models.sequelize.query(`
        CREATE TABLE IF NOT EXISTS verification_attempts (
          id INT AUTO_INCREMENT PRIMARY KEY,
          user_id VARCHAR(255) NOT NULL,
          attempt_type ENUM('email_verification', 'password_change', 'login') NOT NULL,
          success BOOLEAN DEFAULT FALSE,
          ip_address VARCHAR(45) NULL,
          user_agent TEXT NULL,
          created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
          INDEX idx_user_id (user_id),
          INDEX idx_created_at (created_at)
        )
      `);
      
      await models.sequelize.query(`
        CREATE TABLE IF NOT EXISTS user_activity_log (
          id INT AUTO_INCREMENT PRIMARY KEY,
          user_id VARCHAR(255) NOT NULL,
          activity_type ENUM('login', 'logout', 'password_change', 'email_change', 'profile_update', 'profile_picture_update') NOT NULL,
          description TEXT NULL,
          ip_address VARCHAR(45) NULL,
          user_agent TEXT NULL,
          metadata JSON NULL,
          created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
          INDEX idx_user_id (user_id),
          INDEX idx_activity_type (activity_type)
        )
      `);
      
      console.log('✅ Verification tables ensured');
    } catch (error) {
      if (!error.message.includes('already exists')) {
        console.log('⚠️  Verification tables setup:', error.message);
      }
    }
  })
  .catch(err => {
    console.error("❌ Sync failed:", err);
  });

