{
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:backend": "jest src/__tests__ --coverage",
    "test:frontend": "jest src/feature-module/__tests__ --coverage",
    "lint": "eslint src --fix",
    "audit": "npm audit"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.{js,ts,tsx}",
      "!src/**/*.d.ts",
      "!src/**/index.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
